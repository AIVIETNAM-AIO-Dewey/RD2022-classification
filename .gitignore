```gitignore
# ==========================================
# Python
# ==========================================

__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
env/
.venv/

# ==========================================
# Jupyter Notebook
# ==========================================

.ipynb_checkpoints/

# ==========================================
# IDE
# ==========================================

.vscode/
.idea/

# ==========================================
# Operating System
# ==========================================

.DS_Store
Thumbs.db

# ==========================================
# Logs
# ==========================================

logs/
*.log

# ==========================================
# Model Checkpoints
# ==========================================

*.pth
*.pt
*.h5
*.ckpt
*.onnx

outputs/models/

# ==========================================
# Generated Outputs
# ==========================================

outputs/figures/
outputs/reports/
outputs/logs/

# ==========================================
# Dataset
# ==========================================

data/raw/
data/processed/
data/splits/

# Nếu muốn giữ cấu trúc thư mục nhưng không commit dữ liệu:
# tạo file .gitkeep trong mỗi thư mục

# ==========================================
# Temporary Files
# ==========================================

*.tmp
*.temp
*.bak

# ==========================================
# Cache
# ==========================================

.cache/
.pytest_cache/

# ==========================================
# TensorBoard
# ==========================================

runs/
events.out.tfevents.*

# ==========================================
# Experiment Artifacts
# ==========================================

experiments/*/results.csv
experiments/*/logs/
experiments/*/figures/
```
